# ============================================================
# PROSPECT-AI — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS committer le fichier .env dans git
# ============================================================

# --- Sélection du provider LLM ---
# Valeurs : "groq" (défaut) | "anthropic"
LLM_PROVIDER=groq

# --- Groq (provider actif par défaut) ---
# Clé API sur : https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# --- Anthropic / Claude (provider alternatif) ---
# Décommentez et renseignez pour revenir à Claude :
#   LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# --- Base de données SQLite ---
DATABASE_URL=sqlite:///./data/prospect_ai.db

# --- API BCE / KBO (pas de clé requise pour l'API publique) ---
BCE_API_BASE_URL=https://kbopub.economie.fgov.be/kbopub/trefwoordenSearchAction.do
BCE_OPEN_DATA_URL=https://api.kbopub.be/v1
BCE_RATE_LIMIT_RPS=10

# --- BNB — Banque Nationale de Belgique (inscription gratuite) ---
BNB_API_KEY=
BNB_API_BASE_URL=https://www.nbb.be/api/coa/v1

# --- Recherche Web (optionnel) ---
SERPAPI_KEY=
DUCKDUCKGO_ENABLED=true

# --- Données de contact (optionnel) ---
HUNTER_IO_API_KEY=
APOLLO_API_KEY=

# --- Paramètres applicatifs ---
APP_NAME=PROSPECT-AI
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Seuils Phase 3
PHASE3_MIN_SCORE=0.45
PHASE3_MIN_SCORE_FALLBACK=0.35
PHASE3_TARGET_COMPANIES=30

# Cache TTL (en secondes)
CACHE_BCE_TTL=86400
CACHE_BNB_TTL=604800
CACHE_SCRAPING_TTL=43200

# Alertes coût LLM (en USD)
LLM_COST_ALERT_THRESHOLD=5.0
